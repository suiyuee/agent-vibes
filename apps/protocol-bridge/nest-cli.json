{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      {
        "include": "llm/google/go-worker/**/*",
        "watchAssets": true
      },
      {
        "include": "persistence/migrations/*.sql",
        "watchAssets": true
      }
    ]
  }
}
